import { ListView, Button } from "std-widgets.slint";
struct Version {
    name: string,
    edition: string,
    samvid: int
}

export component MainWindow inherits Window {
    in property <[Version]> input-versions;
    in property <[Version]> output-versions;

    callback set-version(mode: int, edition: string, samvid: int);
    callback browse();
    callback convert();

    title: "Worlds Reincarnate";

    preferred-height: 500px;
    preferred-width: 500px;

    min-height: 300px;
    min-width: 200px;

    background: darkgray;

    GridLayout {
        spacing: 5px;

        header := Rectangle {
            height: 50px;
            opacity: 25%;
            colspan: 5;
            background: green;
        }

        Text { 
            text: "Input Version"; 
            color: white;
            row: 2;
            col: 2;
        }

        input-versions := ListView {
            rowspan: 2;
            min-height: 100px;
            min-width: 50px;
            horizontal-scrollbar-policy: always-off;
            row: 3;
            col: 2;

            for version in root.input-versions:
                Button {
                    height: 25px;
                    text: version.name;
                    clicked() => {
                        root.set-version(0, version.edition, version.samvid);
                    }
                }
        }

        Button {
            row: 2;
            col: 3;
            text: "Browse";
            clicked() => {
                root.browse();
            }
        }

        Button {
            row: 3;
            col: 3;
            text: "Convert";
            clicked() => {
                root.convert();
            }
        }

        Text { 
            text: "Output Version"; 
            color: white;
            row: 2;
            col: 4;
        }

        footer := Rectangle {
            height: 50px;
            opacity: 25%;
            colspan: 5;
            row: 5;
            background: green;
        }

    }
}