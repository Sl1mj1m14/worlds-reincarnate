import { ConvertScreen, Versions, Constants } from "convert.slint";
import { LoadScreen } from "load.slint";
import { UIState, State } from "states.slint";

export { Versions, Constants, UIState, State }

export component MainWindow inherits Window {

    title: "Worlds Reincarnate";

    preferred-height: 500px;
    preferred-width: 500px;

    min-height: 300px;
    min-width: 200px;

    loading-screen := LoadScreen { height: root.height; width: root.width; }
    converting-screen := ConvertScreen { height: root.height; width: root.width; }

    states [
        loading when (UIState.state == State.load) : {
            loading-screen.visible: true;
            converting-screen.visible: false;
        }
        converting when (UIState.state == State.convert) : {
            loading-screen.visible: false;
            converting-screen.visible: true;
        }
    ]
}